pipeline {

    agent any
    parameters {

        string(name: 'IMAGE_TAG',defaultValue: 'v1',description: 'Docker image tag')


    }
    stages{

        stage('Update Helm Values'){

            steps{
                sh"""
                sed -i 's/tag:.*/tag: "'" ${IMAGE_TAG}"'"/'soulmateapp-chart/values.yaml
                """
            }

            
        }

        stage('Helm Deploy'){
            steps{
                sh 'helm upgrade --install soulmateapp soulmateapp-chart'
            }
        }

        stage('Verify Deployment'){
            steps{
                sh 'kubectl get pods'
                sh  'kubectl get pods -w'
                sh 'kubectl get svc'
            }
        }


    }



 post {

        success {
            echo 'Deployment SUCCESSFUL'
            echo 'Application deployed to Kubernetes successfully.'
        }

        failure {
            echo 'Deployment FAILED'
            echo 'Check Kubernetes/Helm logs.'
        }

        always {
            echo 'CD Pipeline Finished.'
        }
    }


     
}