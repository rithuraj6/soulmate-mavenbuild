pipeline{

    agent any

    tools{
        maven 'Maven'
    }


    stages{
        stage('Build'){
            steps{
                sh 'mvn clean package'
            }
        }

        stage('Test'){
            steps{
                sh 'mvn test'
            }
        }


        stage('SonarQube Analysis'){
            steps{
                withSonarQubeEnv('sonar-server'){
                    sh'''
                    mvn sonar:sonar \
                    -Dsonar.projectKey=soulmateapp \
                    '''
                }
            }
        }


        stage('Quality Gate'){
            steps{
                timeout(time: 2, unit: 'MINUTES'){
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('OWASP Scan'){
            steps{
                sh 'mvn dependency-check:check' 
            }
        }


        stage('Docker Build'){
            steps{
                sh 'docker build -t rithuraj6/soulmateapp:v1 .'
            }


        }

        stage('Trivy Scan'){
            steps{
                sh 'trivy image rithuraj6/soulmateapp:v1'
            }
        }

        stage('Docker Push'){
            steps{
                sh 'docker push rithuraj6/soulmateapp:v1'
            }
        }

        

        stage('Cleanup'){
            steps{
                sh 'docker rmi rithuraj6/soulmateapp:v1 || true'
            }
        }



    }
}