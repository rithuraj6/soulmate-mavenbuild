

pipeline {

    agent any
    tools{
        maven 'Maven'
    }

    environment {

        IMAGE_NAME = "rithuraj6/soulmateapp"
        IMAGE_TAG = "v1"

    }

    stages {

        stage('Build') {

            steps {

                sh 'mvn clean package'

            }

        }

        stage('OWASP Scan') {

            steps {

                sh 'mvn dependency-check:check'

            }

        }

        stage('Trivy Scan') {

            steps {

                sh 'trivy image ${IMAGE_NAME}:${IMAGE_TAG} || true'

            }

        }

        stage('SonarQube Analysis') {

            steps {

                withSonarQubeEnv('sonar-server') {

                    sh '''
                    mvn sonar:sonar \
                    -Dsonar.projectKey=soulmateapp
                    '''

                }

            }

        }

        stage('Docker Build') {

            steps {

                sh 'docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .'

            }

        }

        stage('Docker Push') {

            steps {

                sh 'docker push ${IMAGE_NAME}:${IMAGE_TAG}'

            }

        }

        stage('Cleanup Docker Image') {

            steps {

                sh 'docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true'

            }

        }

        stage('Trigger Deploy Pipeline') {

            steps {

                echo 'Triggering deploy pipeline now...'

                build job: 'springboot-deploy'

                echo 'Deploy pipeline triggered successfully.'

            }

        }

    }

    post {

        success {

            echo 'Build SUCCESSFUL'
            echo 'CI Pipeline completed successfully.'

        }

        failure {

            echo 'Build FAILED'
            echo 'Check Jenkins console logs.'

        }

        always {

            echo 'CI Pipeline Finished.'

        }

    }

}  