pipeline{

    agent any

    stages{

        stage('Build'){
            steps{
                sh 'mvn clean package'
            }
        }

        stage('OWASP Scan'){
            steps{
                sh 'mvn dependency-check:check'
            }
        }

        stage('Trivy Scan'){
            steps{
                 sh 'trivy image soulmateapp:v1'
            }
        }

        stage('SonarQube Analysis'){
            steps{

                withSonarQubeEnv('sonar-server'){
                    sh '''
                    mvn sonar:sonar \
                    -Dsonar.projectKey=soulmateapp
                    '''
                }
            }
        }

        stage('Trigger Deploy Pipeline'){
            steps{
                build job: 'springboot-deploy'
            }
        }

        

    }

    post {

        success {
            echo 'Build SUCCESSFUL'
            echo 'Pipeline Job completed successfully. Deploy pipeline triggered now!'
        }

        failure {
            echo 'Build FAILED'
            echo 'Check build logs.'
        }

        always {
            echo 'CI Pipeline Finished.'
        }
    }

}